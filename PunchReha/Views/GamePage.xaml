<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PunchReha.ViewModels"
             xmlns:converters="clr-namespace:PunchReha.Converters"
             x:Class="PunchReha.Views.GamePage"
             x:DataType="vm:GameViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#0A0A1A">

    <ContentPage.Resources>
        <converters:PercentConverter x:Key="PercentConverter" />
        <converters:MsToSecondsConverter x:Key="MsToSecondsConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="56,*,80">

        <!-- Stats Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*" ColumnSpacing="0"
              BackgroundColor="#1A1A2E" Padding="8,4">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="⏱️" FontSize="12" HorizontalOptions="Center" />
                <Label Text="{Binding TimeRemainingMs, Converter={StaticResource MsToSecondsConverter}}"
                       FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="🎯" FontSize="12" HorizontalOptions="Center" />
                <Label Text="{Binding Score}" FontSize="16" FontAttributes="Bold"
                       TextColor="#FFD700" HorizontalOptions="Center" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="🔥" FontSize="12" HorizontalOptions="Center" />
                <Label FontSize="16" FontAttributes="Bold" TextColor="#FF6B35" HorizontalOptions="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="x{0}">
                            <Binding Path="Stats.Combo" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="📊" FontSize="12" HorizontalOptions="Center" />
                <Label FontSize="16" FontAttributes="Bold" TextColor="#4FC3F7" HorizontalOptions="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="{0}%">
                            <Binding Path="Stats.Accuracy" Converter="{StaticResource PercentConverter}" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </VerticalStackLayout>
        </Grid>

        <!-- Game Area -->
        <Grid Grid.Row="1" x:Name="GameArea" BackgroundColor="#0A0A1A">
            <GraphicsView x:Name="GameCanvas" />
            
            <!-- Countdown overlay -->
            <VerticalStackLayout x:Name="CountdownOverlay"
                                 HorizontalOptions="Center" VerticalOptions="Center"
                                 IsVisible="False">
                <Label x:Name="CountdownLabel" Text="3"
                       FontSize="96" FontAttributes="Bold"
                       TextColor="#FF6B35" HorizontalOptions="Center" />
                <Label Text="Bereit machen!"
                       FontSize="20" TextColor="White" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Paused overlay -->
            <Grid x:Name="PausedOverlay" BackgroundColor="#AA000000" IsVisible="False">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="⏸️ Pausiert" FontSize="36" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Button Text="▶ Weiter" Clicked="OnResumeClicked"
                            BackgroundColor="#4CAF50" TextColor="White"
                            WidthRequest="200" HeightRequest="56" FontSize="18"
                            HorizontalOptions="Center" Margin="0,24,0,0" />
                </VerticalStackLayout>
            </Grid>

            <!-- Waiting message -->
            <Label x:Name="WaitingLabel" Text="⚡ Warte auf Ziele..."
                   TextColor="#555555" FontSize="16"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Power Bar (real-time feedback) -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" BackgroundColor="#1A1A2E" Padding="12,8">
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="16">
                <Label Grid.Column="0">
                    <Label.Text>
                        <MultiBinding StringFormat="💪 Max: {0}">
                            <Binding Path="Stats.MaxPower" Converter="{StaticResource PercentConverter}" />
                        </MultiBinding>
                    </Label.Text>
                    <Label.FontSize>11</Label.FontSize>
                    <Label.TextColor>#888888</Label.TextColor>
                </Label>
                <Label Grid.Column="1">
                    <Label.Text>
                        <MultiBinding StringFormat="📊 Avg: {0}">
                            <Binding Path="Stats.AvgPower" Converter="{StaticResource PercentConverter}" />
                        </MultiBinding>
                    </Label.Text>
                    <Label.FontSize>11</Label.FontSize>
                    <Label.TextColor>#888888</Label.TextColor>
                    <Label.HorizontalTextAlignment>Center</Label.HorizontalTextAlignment>
                </Label>
                <Label Grid.Column="2" Text="{Binding SensorMode, StringFormat='📡 {0}'}"
                       FontSize="11" TextColor="#555555" HorizontalTextAlignment="End" />
            </Grid>
            <GraphicsView Grid.Row="1" x:Name="PowerGauge" HeightRequest="20" />
        </Grid>
    </Grid>

</ContentPage>
