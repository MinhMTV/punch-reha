<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PunchReha.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Dark Theme Colors -->
            <Color x:Key="PageBackgroundColor">#0A0A1A</Color>
            <Color x:Key="CardBackgroundColor">#1A1A2E</Color>
            <Color x:Key="PrimaryColor">#FF6B35</Color>
            <Color x:Key="AccentColor">#4FC3F7</Color>
            <Color x:Key="TextPrimaryColor">White</Color>
            <Color x:Key="TextSecondaryColor">#888888</Color>
            <Color x:Key="SuccessColor">#4CAF50</Color>
            <Color x:Key="DangerColor">#E53935</Color>

            <!-- Global Styles -->
            <Style TargetType="Page" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
                <Setter Property="Shell.NavBarIsVisible" Value="True" />
            </Style>

            <Style TargetType="NavigationPage">
                <Setter Property="BarBackgroundColor" Value="{StaticResource CardBackgroundColor}" />
                <Setter Property="BarTextColor" Value="White" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="14" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
